# Anthropic API key (for planning agent)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase (get from your project dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_anon_key_here

# Python engine URL (default for local dev)
# In Docker this will be http://engine:8000
ENGINE_URL=http://localhost:8000
